{{ define "dialect/sql/client/open" }}
	var (
		drv dialect.Driver
		err error
	)
	if driverName == dialect.YDB {
		drv, err = ydb.Open(context.Background(), dataSourceName)
	} else {
		drv, err = sql.Open(driverName, dataSourceName)
	}
	if err != nil {
		return nil, err
	}
	return NewClient(append(options, Driver(drv))...), nil
{{ end }}
